<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Proyecto2Propina.MainPage">

       <ScrollView Orientation="Vertical">
              <Grid x:Name="ColorContainer"
                       Padding="16"
                       BackgroundColor="#0d1117"
                       RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                       RowSpacing="16">
                     <Label x:Name="ConsumoLabel"
                            Grid.Row="1"
                            Text="Consumo total (CLP): "
                            FontSize="16"
                            TextColor="White" />

                     <Entry x:Name="ConsumoEntry"
                            Grid.Row="2"
                            Placeholder="Ingrese el consumo total"
                            PlaceholderColor="DarkGray"
                            Keyboard="Numeric"
                            ReturnType="Done"
                            BackgroundColor="White"
                            TextColor="Black" />
                     
                     <Label x:Name="PropinaLabel"
                            Grid.Row="3"
                            Text="Porcentaje de propina: "
                            FontSize="16"
                            TextColor="White" />
              </Grid>
       </ScrollView>

</ContentPage>
